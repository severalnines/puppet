## /etc/default/cmon  –  generated by Puppet clustercontrol module
## Points cmon-events and cmon-cloud to their local service endpoints.
EVENTS_CLIENT="http://127.0.0.1:9510"
CLOUD_SERVICE="http://127.0.0.1:9518"

## Keep cmon in foreground so systemd Type=simple can track it correctly.
## Without this, cmon daemonizes (forks) and systemd considers it 'exited',
## then kills the surviving cmon process after ~5 seconds.
EXTRA_OPTS="--nodaemon"
