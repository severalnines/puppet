[client]
port = 3306
socket = <%= @mysql_socket %>

[mysqld]
port = 3306
bind-address = 127.0.0.1
datadir = /var/lib/mysql
socket = <%= @mysql_socket %>
pid-file = <%= @mysql_pid_file %>
log-error = error.log

symbolic-links = 0
skip-name-resolve

# User is ignored when systemd is used (fedora >= 15).
user = mysql

key_buffer_size = 32M
max_allowed_packet = 16M
table_open_cache = 256
sort_buffer_size = 1M
read_buffer_size = 1M
read_rnd_buffer_size = 4M
thread_cache_size = 16
max_connections = 151
wait_timeout = 28800

# MySQL 8.4 LTS: enable legacy mysql_native_password plugin
# Required by ClusterControl's cmon user authentication
mysql_native_password = ON

# InnoDB settings.
innodb_file_per_table = 1
<%
  mem_mb = begin
    scope.lookupvar("facts").dig('memory', 'system', 'total_bytes').to_i / 1024 / 1024
  rescue
    512
  end
  mem_mb = 512 if mem_mb.nil? || mem_mb == 0
  innodb_pool = (mem_mb / 2).round
-%>
innodb_buffer_pool_size = <%= innodb_pool %>M
innodb_log_file_size = 64M
innodb_log_buffer_size = 8M
innodb_flush_log_at_trx_commit = 1
innodb_lock_wait_timeout = 50

[mysqldump]
quick
max_allowed_packet = 64M

[mysqld_safe]
pid-file = <%= @mysql_pid_file %>
log-error = error.log
