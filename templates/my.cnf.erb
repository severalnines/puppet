# ClusterControl - MySQL/MariaDB configuration
# Generated by Puppet clustercontrol module
# Supports: EL 7/8/9, Ubuntu 18/20/22/24, Debian 9/10/11/12, SLES 15+

[mysqld]
user             = mysql
basedir          = /usr
datadir          = /var/lib/mysql
port             = 3306
log-error        = /var/log/mysqld.log

### INNODB
<%
  # memorysize_mb: Facter 3/4 uses facts['memory']['system']['total_bytes']
  # Fall back to 512MB if fact is unavailable
  mem_mb = begin
    scope.lookupvar("facts")&.dig('memory', 'system', 'total_bytes').to_i / 1024 / 1024
  rescue
    0
  end
  mem_mb = 512 if mem_mb.nil? || mem_mb == 0
  innodb_pool = (mem_mb / 2).round
  os_name    = scope.lookupvar("facts")&.dig('os', 'name').to_s.downcase
  os_family  = scope.lookupvar("facts")&.dig('os', 'family').to_s.downcase
  os_major   = scope.lookupvar("facts")&.dig('os', 'release', 'major').to_i
%>
innodb-buffer-pool-size        = <%= innodb_pool %>M
innodb-flush-log-at-trx-commit = 2
innodb-file-per-table          = 1
innodb-log-files-in-group      = 2
innodb-thread-concurrency      = 0
innodb-flush-method            = O_DIRECT

<%# innodb_locks_unsafe_for_binlog is removed in MySQL 8.0 / MariaDB 10.6+     %>
<%# Skip it on: Ubuntu >= 20, Debian >= 11, EL >= 9, SLES >= 15 (all use 8.x) %>
<% skip_unsafe_binlog = (os_name == 'ubuntu'  && os_major >= 20) ||
                        (os_name == 'debian'  && os_major >= 11) ||
                        (os_family == 'redhat' && os_major >= 9)  ||
                        (os_family == 'suse'   && os_major >= 15) %>
<% unless skip_unsafe_binlog %>
innodb_locks_unsafe_for_binlog = 1
<% end %>

### GENERAL
key-buffer-size          = 8M
max-allowed-packet       = 16M
sort-buffer-size         = 512K
read-buffer-size         = 256K
read-rnd-buffer-size     = 512K
myisam-sort-buffer-size  = 8M
skip-name-resolve
event_scheduler          = ON
memlock                  = 0
sysdate-is-now           = 1
max-connections          = 200
thread-cache-size        = 64
table-open-cache         = 512
lower-case-table-names   = 0

[mysqld_safe]
basedir    = /usr
datadir    = /var/lib/mysql
log-error  = /var/log/mysqld.log
