{
  "name": "severalnines-clustercontrol",
  "version": "3.0.0",
  "author": "Jessie Baynas",
  "summary": "Installs and configures ClusterControl 2.4.x (MCC mode).",
  "license": "Apache-2.0",
  "source": "https://github.com/severalnines/puppet",
  "project_page": "https://forge.puppetlabs.com/severalnines/clustercontrol",
  "issues_url": "https://github.com/severalnines/puppet/issues",
  "dependencies": [],
  "operatingsystem_support": [
    { "operatingsystem": "RedHat",      "operatingsystemrelease": ["8", "9"] },
    { "operatingsystem": "CentOS",      "operatingsystemrelease": ["8"] },
    { "operatingsystem": "Rocky",       "operatingsystemrelease": ["8", "9"] },
    { "operatingsystem": "AlmaLinux",   "operatingsystemrelease": ["8", "9"] },
    { "operatingsystem": "OracleLinux", "operatingsystemrelease": ["8", "9"] },
    { "operatingsystem": "Debian",      "operatingsystemrelease": ["11", "12"] },
    { "operatingsystem": "Ubuntu",      "operatingsystemrelease": ["20.04", "22.04", "24.04"] }
  ],
  "requirements": [
    { "name": "puppet", "version_requirement": ">= 7.0 < 9.0" }
  ],
  "description": "Installs and configures ClusterControl 2.4.x using MCC (cmon-proxy) as the web server. Supports MySQL 8.4 Community Server on RHEL-family and Debian/Ubuntu."
}
